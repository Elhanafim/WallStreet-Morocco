# Database
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Auth
NEXTAUTH_SECRET="your-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# APIs
NEXT_PUBLIC_PRICE_SERVICE_URL="http://localhost:8001"
FINNHUB_API_KEY="your_finnhub_api_key"

# AI Assistant — Casablanca (powered by Anthropic Claude)
# Get your key at https://console.anthropic.com → API Keys → Create Key
# Add to Vercel: Project Settings → Environment Variables → ANTHROPIC_API_KEY
# Scope: Production + Preview (server-side only, never exposed to the client)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Revolut (International donations)
# Never commit real values — see .env.local for actual keys
NEXT_PUBLIC_DONATE_REVOLUT_BENEFICIARY="FULL NAME"
NEXT_PUBLIC_DONATE_REVOLUT_IBAN="FR76 XXXX XXXX XXXX XXXX XXXX XXX"
NEXT_PUBLIC_DONATE_REVOLUT_BIC="REVOFRP2"
NEXT_PUBLIC_DONATE_REVOLUT_BANK="Revolut Bank UAB"
NEXT_PUBLIC_DONATE_REVOLUT_ADDRESS="Bank address"
NEXT_PUBLIC_DONATE_REVOLUT_CORRESPONDENT_BIC="XXXXXXXX"
NEXT_PUBLIC_DONATE_REVOLUT_USERNAME="@your_username"
NEXT_PUBLIC_DONATE_REVOLUT_LINK="https://revolut.me/your_username"

# Attijari (Morocco local donations)
NEXT_PUBLIC_DONATE_ATTIJARI_BENEFICIARY="Full Name"
